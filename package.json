{
  "name": "mcp-git-auditor",
  "version": "1.0.0",
  "description": "MCP server for auditing Git repositories against software engineering standards",
  "main": "dist/server.js",
  "bin": {
    "mcp-git-auditor": "dist/server.js"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": ["mcp", "git", "audit", "software-engineering", "iso", "ieee", "code-quality", "standards", "compliance", "mcp-server"],
  "author": "Mosipro1 <https://github.com/Mosipro1>",
  "homepage": "https://github.com/Mosipro1/mcp-git-auditor",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mosipro1/mcp-git-auditor.git"
  },
  "bugs": {
    "url": "https://github.com/Mosipro1/mcp-git-auditor/issues"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "simple-git": "^3.22.0",
    "fast-glob": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "ts-jest": "^29.1.2",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0"
  }
}
