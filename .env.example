# MCP Git Auditor Environment Configuration

# ============================================
# Security Limits
# ============================================

# Maximum file size to scan (bytes)
# Default: 10485760 (10MB)
MAX_FILE_SIZE=10485760

# Maximum total size of all files (bytes)
# Default: 1073741824 (1GB)
MAX_TOTAL_SIZE=1073741824

# Maximum number of files to scan
# Default: 10000
MAX_FILES=10000

# ============================================
# Timeouts
# ============================================

# Total scan timeout (milliseconds)
# Default: 300000 (5 minutes)
SCAN_TIMEOUT_MS=300000

# Git operations timeout (milliseconds)
# Default: 30000 (30 seconds)
GIT_TIMEOUT_MS=30000

# Individual file read timeout (milliseconds)
# Default: 5000 (5 seconds)
FILE_READ_TIMEOUT_MS=5000

# ============================================
# Git Limits
# ============================================

# Maximum commits to analyze
# Default: 5000
MAX_COMMITS=5000

# Maximum branches to analyze
# Default: 100
MAX_BRANCHES=100

# ============================================
# Path Validation
# ============================================

# Comma-separated list of allowed base paths
# Empty = any path allowed
# Example: ALLOWED_BASE_PATHS=/home/user/projects,/opt/repos
ALLOWED_BASE_PATHS=

# Block path traversal attempts
# Default: true
BLOCK_PATH_TRAVERSAL=true

# ============================================
# Logging
# ============================================

# Log level: debug, info, warn, error
# Default: info
LOG_LEVEL=info

# Sanitize paths in output (hide absolute paths)
# Default: true
SANITIZE_PATHS=true

# ============================================
# Node.js Environment
# ============================================

NODE_ENV=production
